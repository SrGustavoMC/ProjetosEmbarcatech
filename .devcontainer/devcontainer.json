{
    "name": "Workspace EmbarcaTech",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "raspberry-pi.raspberry-pi-pico"
            ],
            "settings": {
                "cmake.environment": {
                    "PICO_SDK_PATH": "/opt/pico-sdk"
                },
                "cmake.generator": "Unix Makefiles",
                "cmake.configureOnOpen": true
            }
        }
    },
    "remoteEnv": {
        "PICO_SDK_PATH": "/opt/pico-sdk"
    }
}
